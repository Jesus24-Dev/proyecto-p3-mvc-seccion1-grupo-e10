// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum roles {
  USER
  ADMIN
  DISTRIBUTOR
  // Máximo nivel de permisos: único que puede enviar contactos a la papelera
  // o eliminarlos definitivamente (con todo su historial).
  SUPERADMIN
}

// Rol de un usuario DENTRO de una agencia (subcuenta), estilo GHL:
// define qué puede hacer en esa agencia, independiente de su rol global.
enum agency_role {
  OWNER    // Propietario: control total de la subcuenta.
  MANAGER  // Gerente: gestiona miembros, envíos y paquetes.
  OPERATOR // Operador: registra y actualiza envíos y paquetes.
  VIEWER   // Lector: solo lectura.
}

enum package_status {
  RECEIVED         // Recibido en la agencia de origen.
  IN_TRANSIT       // Viajando entre agencias.
  IN_WAREHOUSE     // En almacén de la agencia destino.
  OUT_FOR_DELIVERY // En reparto de última milla.
  DELIVERED        // Entregado al destinatario.
  RETURNED         // Devuelto al remitente.
}

enum transfer_status {
  CREATED         // El usuario creó la orden pero no ha pagado.
  PENDING_PAYMENT // Esperando depósito bancario o confirmación de tarjeta.
  IN_REVIEW       // Retenido por validación de seguridad o cumplimiento (AML/KYC).
  PROCESSING      // Pago confirmado, el dinero se está enviando al destino.
  READY_FOR_PICKUP // (Si es efectivo) El beneficiario ya puede cobrarlo.
  COMPLETED       // El dinero fue entregado o depositado con éxito.
  CANCELLED       // El usuario canceló la operación antes del envío.
  FAILED          // Error técnico o rechazo bancario.
  REFUNDED        // El dinero fue devuelto al remitente.
}

// Estado de validación de un pago reportado por el cliente.
enum payment_status {
  PENDING   // Reportado, aún sin validar contra el banco.
  APPROVED  // Validado y aprobado.
  REJECTED  // No coincide (monto/fecha/referencia) o rechazado.
}

// Medio por el que se recibió el pago.
enum payment_method {
  TRANSFER       // Transferencia bancaria.
  MOBILE_PAYMENT // Pago móvil.
  CASH           // Efectivo.
}

// Momento del cobro del envío/paquete.
enum payment_kind {
  PREPAID // Envío pagado (el remitente paga en origen).
  COLLECT // Cobro destino (el destinatario paga al recibir).
}

model users {
  id String @id @default(uuid())
  email String @unique
  password String
  role roles

  // Verificación de correo: la cuenta no puede iniciar sesión hasta verificar.
  email_verified Boolean @default(false)
  verification_token String? @unique
  verification_expires DateTime?

  // Recuperación de contraseña (enlace por correo, simulado).
  reset_token String? @unique
  reset_expires DateTime?

  // Inicio de sesión con enlace mágico (passwordless).
  magic_token String? @unique
  magic_expires DateTime?

  user_information users_information?
  orders_by_user orders[]
  agencies_by_user agencies[]
  memberships agency_members[]
}

model users_information {
  id String @id @default(uuid())
  first_name String
  last_name String
  // Cédula o RIF del cliente.
  document_id String @default("")
  phone String @default("")
  address String
  birthday DateTime @db.Date
  created_at DateTime @default(now())
  // Etiquetas de segmentación (usadas por las automatizaciones).
  tags String[] @default([])
  // Papelera: fecha en que se envió a la papelera (soft-delete). null = activo.
  // Al enviar a la papelera se ocultan también sus paquetes y pagos.
  deleted_at DateTime?

  user_id String @unique
  user users @relation(fields: [user_id], references: [id])

  // Agencia (subcuenta) a la que pertenece el contacto. Todo contacto tiene
  // una: se asigna la subcuenta activa al crearlo. Base del alcance por
  // ubicación (un administrador de sede solo ve los de su agencia).
  agency_id String?
  agency agencies? @relation(fields: [agency_id], references: [id])

  packages packages[]
  transactions transactions[]
  notes client_notes[]
  // Inscripciones del contacto en automatizaciones.
  automation_runs automation_runs[]
}

// Tipo de anotación del historial CRM del cliente.
enum note_kind {
  NOTE        // Nota interna
  OBSERVATION // Observación
  INCIDENT    // Incidencia
}

// Historial CRM: notas internas, observaciones e incidencias de un cliente.
model client_notes {
  id String @id @default(uuid())
  kind note_kind @default(NOTE)
  body String
  author_email String @default("")
  created_at DateTime @default(now())

  contact_id String
  contact users_information @relation(fields: [contact_id], references: [id], onDelete: Cascade)

  @@index([contact_id])
}

model agencies {
  id String @id @default(uuid())
  name String
  location String
  is_active Boolean
  // Coordenadas de la agencia (para el mapa de rastreo de paquetes).
  latitude Float?
  longitude Float?

  user_id String
  user users @relation(fields: [user_id], references: [id])
  // Configuración de apariencia de la subcuenta (acento, radio).
  theme Json?
  // Distribución de widgets del panel guardada por el usuario (editable).
  dashboard_layout Json?

  origin_orders orders[] @relation("OriginAgency")
  destination_orders orders[] @relation("DestinationAgency")
  members agency_members[]
  package_events package_events[]
  tags tags[]
  email_templates email_templates[]
  email_domains email_domains[]
  contacts users_information[]
  automations automations[]
}

// Plantillas de correo de una subcuenta (agencia). El cuerpo admite variables
// {{token}} igual que los mensajes de las automatizaciones.
model email_templates {
  id String @id @default(uuid())
  name String
  subject String @default("")
  body String @default("")
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  agency_id String
  agency agencies @relation(fields: [agency_id], references: [id], onDelete: Cascade)

  @@unique([agency_id, name])
}

enum email_domain_status {
  PENDING  // Agregado, pendiente de verificación.
  VERIFIED // Verificado; se puede enviar desde este dominio.
}

// Dominios de envío configurados a nivel de subcuenta (agencia).
model email_domains {
  id String @id @default(uuid())
  domain String
  status email_domain_status @default(PENDING)
  created_at DateTime @default(now())

  agency_id String
  agency agencies @relation(fields: [agency_id], references: [id], onDelete: Cascade)

  @@unique([agency_id, domain])
}

// Catálogo de etiquetas de una subcuenta (agencia), estilo GHL: se aplican
// por nombre a los contactos (users_information.tags) y las usan las
// automatizaciones.
model tags {
  id String @id @default(uuid())
  name String
  // Color del preset (ver NODE_COLORS en el frontend); "" = neutro.
  color String @default("")
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  agency_id String
  agency agencies @relation(fields: [agency_id], references: [id], onDelete: Cascade)

  @@unique([agency_id, name])
}

// Membresía de un usuario en una agencia (subcuenta) con su rol interno.
model agency_members {
  id String @id @default(uuid())
  role agency_role @default(OPERATOR)
  created_at DateTime @default(now())

  agency_id String
  agency agencies @relation(fields: [agency_id], references: [id], onDelete: Cascade)

  user_id String
  user users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([agency_id, user_id])
}

// Flujos de automatización creados en el editor visual; la definición
// guarda los nodos y conexiones del lienzo (formato React Flow).
model automations {
  id String @id @default(uuid())
  name String
  description String @default("")
  // Carpeta para organizar los flujos en el panel ("" = sin carpeta).
  folder String @default("")
  is_active Boolean @default(false)
  definition Json
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Subcuenta (agencia) dueña del flujo. Las automatizaciones son únicas por
  // subcuenta; null = visible solo en la vista agregada (administradores).
  agency_id String?
  agency agencies? @relation(fields: [agency_id], references: [id])

  // Ejecuciones (inscripciones): un contacto recorriendo el flujo.
  runs automation_runs[]
}

// Estado de una ejecución (inscripción) de un contacto en un flujo.
enum automation_run_status {
  RUNNING   // Avanzando por los pasos.
  WAITING   // Detenido en un paso "esperar", hasta resume_at.
  COMPLETED // Llegó al final del flujo.
  EXITED    // Salió por una rama sin continuación (p. ej. condición "No").
  FAILED    // Error irrecuperable del motor.
}

// Resultado de un paso ejecutado, para el registro (log) de ejecución.
enum automation_event_result {
  OK    // El paso se ejecutó correctamente.
  ERROR // El paso falló (se registra y el flujo continúa cuando es posible).
  INFO  // Evento informativo (inscripción, espera iniciada, etc.).
}

// Una ejecución del flujo: el recorrido de un contacto por los nodos.
// El motor la avanza nodo a nodo; el scheduler despierta las que esperan.
model automation_runs {
  id String @id @default(uuid())

  automation_id String
  automation automations @relation(fields: [automation_id], references: [id], onDelete: Cascade)

  // Contacto inscrito (opcional: los webhooks anónimos no traen contacto).
  contact_id String?
  contact users_information? @relation(fields: [contact_id], references: [id], onDelete: SetNull)

  status automation_run_status @default(RUNNING)
  // Nodo donde está parado el contacto (para pintarlo en el lienzo).
  current_node_id String?
  // Evento que lo inscribió (contact_created, webhook_received, manual, ...).
  trigger String @default("")
  // Variables resueltas del contacto y su paquete/envío al inscribirse.
  context Json?
  // Cuándo despertar un paso "esperar" (null si no está esperando).
  resume_at DateTime?
  started_at DateTime @default(now())
  updated_at DateTime @updatedAt

  events automation_run_events[]

  @@index([status, resume_at])
  @@index([automation_id])
}

// Registro (log) de cada paso ejecutado dentro de una ejecución.
model automation_run_events {
  id String @id @default(uuid())

  run_id String
  run automation_runs @relation(fields: [run_id], references: [id], onDelete: Cascade)

  // Nodo del lienzo ejecutado y su tipo (StepKind del editor).
  node_id String @default("")
  kind String @default("")
  result automation_event_result @default(INFO)
  detail String @default("")
  created_at DateTime @default(now())

  @@index([run_id])
}

// Listas inteligentes: segmentos guardados de contactos definidos por
// condiciones (correo definido/no, teléfono, etiqueta, etc.). El filtrado
// se aplica en el cliente; aquí solo se persiste la definición compartida.
model smart_lists {
  id String @id @default(uuid())
  name String
  // Array de condiciones { field, op, value? }.
  conditions Json
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model orders {
  id String @id @default(uuid())
  date_arrived DateTime @db.Timestamp(3)
  date_received DateTime @db.Timestamp(3)
  description String
  amount Float
  status transfer_status @default(CREATED)

  //Relation with user
  user_id String
  user users @relation(fields: [user_id], references: [id])
  
  //Relation with Agencies
  origin_agency_id String
  origin_agency agencies @relation("OriginAgency", fields: [origin_agency_id], references: [id])
  
  destination_agency_id String
  destination_agency agencies @relation("DestinationAgency", fields: [destination_agency_id], references: [id])

  packages packages[]
  transactions transactions[]
}

model packages {
  id String @id @default(uuid())
  // Código de rastreo generado por el servidor (p. ej. DRL-2026-9F3A21B0).
  tracking_code String @unique
  description String
  weight_kg Float
  // Dimensiones en texto libre, p. ej. "30 × 20 × 15 cm".
  dimensions String @default("")
  status package_status @default(RECEIVED)
  // Fotos del paquete (URLs o data-URIs). Evidencia del contenido/estado.
  image_urls String[] @default([])
  created_at DateTime @default(now())
  // Papelera: se llena cuando el contacto dueño se envía a la papelera.
  // null = visible; con fecha = oculto de listados y tablero.
  deleted_at DateTime?

  // Contacto (destinatario) al que pertenece el paquete.
  contact_id String
  contact users_information @relation(fields: [contact_id], references: [id])

  // Envío (orden) que transporta el paquete; opcional hasta que se despacha.
  order_id String?
  order orders? @relation(fields: [order_id], references: [id])

  // Etapa del pipeline (estado logístico personalizable). Es la fuente de
  // verdad del tablero; `status` se mantiene en sincronía para las etapas
  // del sistema (rastreo/automatizaciones/reportes).
  stage_id String?
  stage pipeline_stages? @relation(fields: [stage_id], references: [id])

  // Historial de movimientos (checkpoints) del paquete.
  events package_events[]

  // Pagos asociados al paquete (envío pagado / cobro destino).
  transactions transactions[]
}

// Etapas del ciclo de vida de un paquete (estados logísticos), personalizables
// a nivel global: todas las cuentas comparten la misma estructura. Las 6
// etapas canónicas (is_system) respaldan un `package_status` para mantener la
// compatibilidad con rastreo, automatizaciones y reportes.
model pipeline_stages {
  id String @id @default(uuid())
  name String
  // Clave de color del preset (ver NODE_COLORS en el frontend); "" = neutro.
  color String @default("")
  // Orden de la etapa en el tablero.
  position Int
  is_active Boolean @default(true)
  // Etapas del sistema: no se pueden eliminar (sí renombrar/reordenar).
  is_system Boolean @default(false)
  // Estado canónico que respalda esta etapa; null en etapas personalizadas.
  status package_status?
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  packages packages[]
}

// Cada movimiento registrado de un paquete: su estado en un momento dado,
// opcionalmente la agencia donde ocurrió, para reconstruir su recorrido.
model package_events {
  id String @id @default(uuid())
  status package_status
  note String @default("")
  created_at DateTime @default(now())

  package_id String
  package packages @relation(fields: [package_id], references: [id], onDelete: Cascade)

  // Agencia (ubicación) del checkpoint; opcional para eventos sin sede.
  agency_id String?
  agency agencies? @relation(fields: [agency_id], references: [id])
}

// Catálogo de roles del sistema con sus permisos por módulo.
// Capa de gestión (no reemplaza el enum `roles` que usa la autenticación).
model app_roles {
  id String @id @default(uuid())
  name String @unique
  description String @default("")
  // Claves de permiso (ver PERMISSION_CATALOG en el frontend).
  permissions String[] @default([])
  // Roles base del sistema: no se pueden eliminar.
  is_system Boolean @default(false)
  created_at DateTime @default(now())
}

// Configuración global del sistema (fila única).
model system_config {
  id String @id @default("singleton")
  company_name String @default("Dr-Logistics CA")
  company_rif String @default("")
  company_address String @default("")
  company_phone String @default("")
  company_email String @default("")
  // Correo remitente y de soporte.
  sender_email String @default("")
  support_email String @default("")
  // Claves de API (simuladas): se guardan pero no se usan en esta entrega.
  bank_api_key String @default("")
  ml_api_key String @default("")
  // Tasa de cambio manual Bs/USD (bolívares por 1 USD). 0 = sin configurar.
  bs_rate Float @default(0)
  updated_at DateTime @default(now()) @updatedAt
}

// Tipo de notificación interna del personal.
enum notification_kind {
  PAYMENT   // Pago validado
  PACKAGE   // Paquete recibido / registrado
  STATE     // Cambio de estado
  DELIVERY  // Entrega realizada
  GENERAL
}

// Notificaciones internas del personal (feed global del equipo).
model notifications {
  id String @id @default(uuid())
  kind notification_kind @default(GENERAL)
  title String
  body String @default("")
  read Boolean @default(false)
  entity_id String?
  created_at DateTime @default(now())

  @@index([created_at])
}

// Bitácora de auditoría: registra acciones críticas del personal.
model audit_logs {
  id String @id @default(uuid())
  // p. ej. "user.create", "package.status_change", "payment.validate".
  action String
  // Entidad afectada: "user", "client", "package", "payment", ...
  entity String
  entity_id String?
  detail String @default("")
  // Usuario que ejecutó la acción (desnormalizado para sobrevivir borrados).
  user_id String?
  user_email String @default("")
  created_at DateTime @default(now())

  @@index([created_at])
}

// Pago reportado por un cliente, validado contra el banco (simulado).
model transactions {
  id String @id @default(uuid())
  // Referencia bancaria reportada por el cliente.
  reference String
  bank String @default("Banco Mercantil")
  amount Float
  status payment_status @default(PENDING)
  // Medio por el que se recibió el pago (transferencia/pago móvil/efectivo).
  method payment_method @default(TRANSFER)
  // Envío pagado (origen) o cobro destino.
  kind payment_kind @default(PREPAID)
  // Fecha del pago reportada por el cliente.
  paid_at DateTime
  // Momento en que se validó/rechazó contra el banco.
  validated_at DateTime?
  note String @default("")
  created_at DateTime @default(now())
  // Papelera: se llena cuando el contacto dueño se envía a la papelera.
  deleted_at DateTime?

  // Cliente (contacto) que reporta el pago.
  contact_id String
  contact users_information @relation(fields: [contact_id], references: [id])

  // Envío (orden) que cubre el pago; opcional.
  order_id String?
  order orders? @relation(fields: [order_id], references: [id])

  // Paquete sobre el que se hace el pago; opcional.
  package_id String?
  package packages? @relation(fields: [package_id], references: [id])
}