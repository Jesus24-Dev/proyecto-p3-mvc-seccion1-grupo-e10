// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum roles {
  USER 
  ADMIN
  DISTRIBUTOR
}

enum package_status {
  RECEIVED         // Recibido en la agencia de origen.
  IN_TRANSIT       // Viajando entre agencias.
  IN_WAREHOUSE     // En almacén de la agencia destino.
  OUT_FOR_DELIVERY // En reparto de última milla.
  DELIVERED        // Entregado al destinatario.
  RETURNED         // Devuelto al remitente.
}

enum transfer_status {
  CREATED         // El usuario creó la orden pero no ha pagado.
  PENDING_PAYMENT // Esperando depósito bancario o confirmación de tarjeta.
  IN_REVIEW       // Retenido por validación de seguridad o cumplimiento (AML/KYC).
  PROCESSING      // Pago confirmado, el dinero se está enviando al destino.
  READY_FOR_PICKUP // (Si es efectivo) El beneficiario ya puede cobrarlo.
  COMPLETED       // El dinero fue entregado o depositado con éxito.
  CANCELLED       // El usuario canceló la operación antes del envío.
  FAILED          // Error técnico o rechazo bancario.
  REFUNDED        // El dinero fue devuelto al remitente.
}

model users {
  id String @id @default(uuid())
  email String @unique
  password String
  role roles 
  
  user_information users_information?
  orders_by_user orders[]
  agencies_by_user agencies[]
}

model users_information {
  id String @id @default(uuid())
  first_name String
  last_name String
  address String
  birthday DateTime @db.Date

  user_id String @unique
  user users @relation(fields: [user_id], references: [id])

  packages packages[]
}

model agencies {
  id String @id @default(uuid())
  name String
  location String
  is_active Boolean

  user_id String
  user users @relation(fields: [user_id], references: [id])

  origin_orders orders[] @relation("OriginAgency")
  destination_orders orders[] @relation("DestinationAgency")
}

model orders {
  id String @id @default(uuid())
  date_arrived DateTime @db.Timestamp(3)
  date_received DateTime @db.Timestamp(3)
  description String
  amount Float
  status transfer_status @default(CREATED)

  //Relation with user
  user_id String
  user users @relation(fields: [user_id], references: [id])
  
  //Relation with Agencies
  origin_agency_id String
  origin_agency agencies @relation("OriginAgency", fields: [origin_agency_id], references: [id])
  
  destination_agency_id String
  destination_agency agencies @relation("DestinationAgency", fields: [destination_agency_id], references: [id])

  packages packages[]
}

model packages {
  id String @id @default(uuid())
  // Código de rastreo generado por el servidor (p. ej. DRL-2026-9F3A21B0).
  tracking_code String @unique
  description String
  weight_kg Float
  status package_status @default(RECEIVED)
  created_at DateTime @default(now())

  // Contacto (destinatario) al que pertenece el paquete.
  contact_id String
  contact users_information @relation(fields: [contact_id], references: [id])

  // Envío (orden) que transporta el paquete; opcional hasta que se despacha.
  order_id String?
  order orders? @relation(fields: [order_id], references: [id])
}