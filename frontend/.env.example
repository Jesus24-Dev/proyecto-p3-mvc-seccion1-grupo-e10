# URL base de la API cuando NO se usa el proxy de Vite (build de producción).
# En desarrollo déjala comentada: si se define, las peticiones saltan el proxy.
# VITE_API_URL=http://localhost:3000

# Destino del proxy de desarrollo de Vite (/auth, /users, /agencies).
# Útil si el backend corre en otro puerto (por ejemplo, 3001).
VITE_PROXY_TARGET=http://localhost:3000
